    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "hono": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "hono": "^4.5.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "zod": "^3.23.0"
  }
}
