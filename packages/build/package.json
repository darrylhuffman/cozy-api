{
  "name": "@cozy/build",
  "version": "0.1.0",
  "description": "Compiler and CLI for cozy-api projects: cozy build (codegen), cozy dev (interpreter), cozy init, cozy import-openapi",
  "license": "MIT",
  "author": "dyudabomb@gmail.com",
  "keywords": [
    "cozy-api",
    "cli",
    "build",
    "codegen",
    "hono",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/cli.js",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./run-build": {
      "types": "./dist/run-build.d.ts",
      "default": "./dist/run-build.js"
    }
  },
  "bin": {
    "cozy": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cozy/openapi": "workspace:*",
    "@cozy/runtime": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "hono": "^4.12.21",
    "tsup": "^8.5.1",
    "vitest": "^4.1.7"
  }
}
