{
  "name": "@darrylondil/lorien-build",
  "version": "0.1.1",
  "description": "Compiler and CLI for lorien projects: lorien build (codegen), lorien dev (interpreter), lorien init, lorien import-openapi",
  "license": "MIT",
  "author": "dyudabomb@gmail.com",
  "keywords": [
    "lorien",
    "cli",
    "build",
    "codegen",
    "hono",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/cli.js",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./run-build": {
      "types": "./dist/run-build.d.ts",
      "default": "./dist/run-build.js"
    }
  },
  "bin": {
    "lorien": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@darrylondil/lorien-ide": "workspace:*",
    "@darrylondil/lorien-openapi": "workspace:*",
    "@darrylondil/lorien-runtime": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "hono": "^4.12.21"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "vitest": "^4.1.7"
  }
}
