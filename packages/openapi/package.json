{
  "name": "@cozy/openapi",
  "version": "0.1.0",
  "description": "OpenAPI 3.x → cozy-api defineNode client generator",
  "license": "MIT",
  "author": "dyudabomb@gmail.com",
  "keywords": [
    "cozy-api",
    "openapi",
    "swagger",
    "codegen",
    "client",
    "zod",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cozy/runtime": "workspace:*",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "vitest": "^4.1.7"
  }
}
